Before:
  let g:_pm_saved_vim_dir = get(g:, 'plugin_manager_vim_dir', '')
  let g:_pm_saved_cwd = getcwd()
  let g:_pm_tmp = tempname()
  call mkdir(g:_pm_tmp, 'p')
  call mkdir(g:_pm_tmp . '/.git', 'p')
  let g:plugin_manager_vim_dir = g:_pm_tmp
  call writefile([
        \ '[submodule "vim-fugitive"]',
        \ '  path = pack/plugins/start/vim-fugitive',
        \ '  url = https://github.com/tpope/vim-fugitive.git',
        \ '[submodule "nerdtree"]',
        \ '  path = pack/plugins/opt/nerdtree',
        \ '  url = https://github.com/preservim/nerdtree.git',
        \ '  branch = master',
        \ ], g:_pm_tmp . '/.gitmodules')
  execute 'cd ' . fnameescape(g:_pm_tmp)

After:
  execute 'cd ' . fnameescape(g:_pm_saved_cwd)
  if isdirectory(g:_pm_tmp)
    call delete(g:_pm_tmp, 'rf')
  endif
  let g:plugin_manager_vim_dir = g:_pm_saved_vim_dir

Execute (parse_modules finds all declared submodules):
  call plugin_manager#git#refresh_modules_cache()
  let mods = plugin_manager#git#parse_modules()
  AssertEqual 2, len(mods)
  Assert has_key(mods, 'vim-fugitive'), 'vim-fugitive should be parsed'
  Assert has_key(mods, 'nerdtree'), 'nerdtree should be parsed'

Execute (parse_modules extracts path, url and short_name):
  call plugin_manager#git#refresh_modules_cache()
  let mods = plugin_manager#git#parse_modules()
  AssertEqual 'pack/plugins/start/vim-fugitive', mods['vim-fugitive'].path
  AssertEqual 'https://github.com/tpope/vim-fugitive.git', mods['vim-fugitive'].url
  AssertEqual 'vim-fugitive', mods['vim-fugitive'].short_name

Execute (parse_modules captures an explicit branch):
  call plugin_manager#git#refresh_modules_cache()
  let mods = plugin_manager#git#parse_modules()
  AssertEqual 'master', mods['nerdtree'].branch

Execute (find_module resolves by short name):
  let info = plugin_manager#git#find_module('nerdtree')
  Assert !empty(info), 'find_module should resolve nerdtree'
  AssertEqual 'pack/plugins/opt/nerdtree', info.module.path

Execute (submodule_exists matches by short_name):
  call plugin_manager#git#refresh_modules_cache()
  Assert plugin_manager#git#submodule_exists('vim-fugitive'), 'short_name vim-fugitive should match'
  Assert plugin_manager#git#submodule_exists('nerdtree'), 'short_name nerdtree should match'

Execute (submodule_exists matches by relative path):
  call plugin_manager#git#refresh_modules_cache()
  Assert plugin_manager#git#submodule_exists('pack/plugins/start/vim-fugitive'), 'relative path should match'

Execute (submodule_exists matches by absolute path):
  call plugin_manager#git#refresh_modules_cache()
  let abs = g:_pm_tmp . '/pack/plugins/start/vim-fugitive'
  " Create the directory so isdirectory would also find it
  call mkdir(g:_pm_tmp . '/pack/plugins/start/vim-fugitive', 'p')
  Assert plugin_manager#git#submodule_exists(abs), 'absolute path should match'

Execute (submodule_exists returns 0 for unknown):
  call plugin_manager#git#refresh_modules_cache()
  Assert !plugin_manager#git#submodule_exists('pack/plugins/start/vim-go'), 'unknown path should not match'

Execute (submodule_exists handles absolute paths in .gitmodules):
  let abs_fixture = tempname()
  call mkdir(abs_fixture, 'p')
  call mkdir(abs_fixture . '/.git', 'p')
  let saved_vimdir = g:plugin_manager_vim_dir
  let g:plugin_manager_vim_dir = abs_fixture
  let abs_path = abs_fixture . '/pack/plugins/opt/myplugin'
  call writefile([
        \ '[submodule "myplugin"]',
        \ '  path = ' . abs_path,
        \ '  url = https://github.com/user/myplugin.git',
        \ ], abs_fixture . '/.gitmodules')
  execute 'cd ' . fnameescape(abs_fixture)
  call plugin_manager#git#refresh_modules_cache()
  Assert plugin_manager#git#submodule_exists(abs_path), 'should match absolute path in .gitmodules'
  Assert plugin_manager#git#submodule_exists('myplugin'), 'should match short_name of absolute-path module'
  let g:plugin_manager_vim_dir = saved_vimdir
  execute 'cd ' . fnameescape(g:_pm_saved_cwd)
  call delete(abs_fixture, 'rf')

Execute (remote_branch_name strips origin/ prefix):
  AssertEqual 'master', plugin_manager#git#remote_branch_name('origin/master')
  AssertEqual 'main', plugin_manager#git#remote_branch_name('origin/main')
  AssertEqual 'feature/foo', plugin_manager#git#remote_branch_name('origin/feature/foo')

Execute (remote_branch_name is idempotent without prefix):
  AssertEqual 'master', plugin_manager#git#remote_branch_name('master')
  AssertEqual 'main', plugin_manager#git#remote_branch_name('main')
  AssertEqual 'origin', plugin_manager#git#remote_branch_name('origin')

Execute (remote_branch_name handles empty input):
  AssertEqual '', plugin_manager#git#remote_branch_name('')

Execute (collect_status_local returns empty status for a missing path):
  let st = plugin_manager#git#collect_status_local('/no/such/path')
  AssertEqual 0, st.behind
  AssertEqual 0, st.has_updates
  AssertEqual 'N/A', st.branch
