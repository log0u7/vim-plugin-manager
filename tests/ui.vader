Before:
  " Work from a scratch user buffer with a known cursor position
  enew!
  call setline(1, ['user 1', 'user 2', 'user 3', 'user 4'])
  call cursor(3, 1)

After:
  " Close the sidebar window if present
  let s:w = bufwinid('PluginManager')
  if s:w != -1
    call win_execute(s:w, 'hide')
  endif

Execute (format_plugin_line aligns name and info):
  let line = plugin_manager#ui#format_plugin_line('+', 'foo', 'Installed')
  Assert line =~# '^+ foo\.\+ Installed$', 'unexpected line: ' . line

Execute (operations do not steal focus from the user window):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  call cursor(3, 1)
  let before = getpos('.')
  let opid = plugin_manager#ui#start_operation('myplugin', 'Installing')
  call plugin_manager#ui#update_operation(opid, 'Cloning')
  call plugin_manager#ui#complete_operation(opid, 1, 'Done')
  let after = getpos('.')
  AssertEqual before[1], after[1], 'cursor line should not move'
  AssertEqual before[2], after[2], 'cursor column should not move'
  AssertNotEqual 'PluginManager', bufname('%'), 'focus should stay in the user window'

Execute (completed operation is rendered in the sidebar buffer):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  let opid = plugin_manager#ui#start_operation('alpha', 'Installing')
  call plugin_manager#ui#complete_operation(opid, 1, 'Installed')
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  Assert content =~# 'alpha', 'sidebar should contain the plugin name'

Execute (show_update_notification lists plugins behind):
  call plugin_manager#ui#show_update_notification([{'name': 'foo', 'behind': 2}])
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  Assert content =~# 'foo', 'should list foo'
  Assert content =~# '2 commits behind', 'should show the behind count'

Execute (show_update_notification reports up-to-date when empty):
  call plugin_manager#ui#show_update_notification([])
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  Assert content =~# 'up-to-date', 'should say up-to-date'

Execute (complete_operation_symbol renders the given glyph in place):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  let opid = plugin_manager#ui#start_operation('myplugin', 'Checking')
  let glyph = plugin_manager#ui#get_symbol('warning')
  call plugin_manager#ui#complete_operation_symbol(opid, glyph, 'Modified (2 commits)')
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  Assert content =~# 'myplugin', 'sidebar should contain the plugin name'
  Assert content =~# 'Modified', 'status text should appear'
  Assert content =~# glyph, 'the provided glyph should appear'

Execute (log_detail routes to log, never opens sidebar):
  let sbuf_before = bufnr('PluginManager')
  call plugin_manager#ui#log_detail('test', 'test detail message')
  let sbuf_after = bufnr('PluginManager')
  AssertEqual sbuf_before, sbuf_after, 'log_detail should not create or remove sidebar buffer'

Execute (helptags silent mode does not produce UI lines):
  let saved_vimdir = get(g:, 'plugin_manager_vim_dir', '')
  let saved_cwd = getcwd()
  let tmp = tempname()
  call mkdir(tmp, 'p')
  call mkdir(tmp . '/.git', 'p')
  let g:plugin_manager_vim_dir = tmp
  execute 'cd ' . fnameescape(tmp)
  call plugin_manager#ui#open_sidebar(['Header'])
  call plugin_manager#cmd#helptags#execute(1, '', 1)
  let sbuf = bufnr('PluginManager')
  let header1 = getbufline(sbuf, 1)[0]
  execute 'cd ' . fnameescape(saved_cwd)
  call delete(tmp, 'rf')
  let g:plugin_manager_vim_dir = saved_vimdir
  AssertEqual 'Header', header1, 'silent mode should not change sidebar'

Execute (helptags non-silent mode opens sidebar on error):
  let saved_vimdir = get(g:, 'plugin_manager_vim_dir', '')
  let saved_cwd = getcwd()
  let tmp = tempname()
  call mkdir(tmp, 'p')
  call mkdir(tmp . '/.git', 'p')
  let g:plugin_manager_vim_dir = tmp
  execute 'cd ' . fnameescape(tmp)
  call plugin_manager#cmd#helptags#execute(1, '', 0)
  let sbuf = bufnr('PluginManager')
  let output = ''
  if sbuf != -1
    let output = join(getbufline(sbuf, 1, '$'), "\n")
  endif
  execute 'cd ' . fnameescape(saved_cwd)
  call delete(tmp, 'rf')
  let g:plugin_manager_vim_dir = saved_vimdir
  Assert output =~# 'Generating helptags\|No plugins found\|Plugin directory not found', 'non-silent should show output'

Execute (header returns [title, separator, empty string]):
  let h = plugin_manager#ui#header('Test section:')
  AssertEqual 3, len(h), 'header should have 3 elements'
  AssertEqual 'Test section:', h[0], 'first element should be the title'
  Assert h[1] =~# '^[━\-]\+$', 'second element should be a separator'
  AssertEqual '', h[2], 'third element should be an empty string'

Execute (open_header opens sidebar with standard header):
  call plugin_manager#ui#open_header('My command:')
  let sbuf = bufnr('PluginManager')
  Assert sbuf != -1, 'sidebar should have been created'
  let lines = getbufline(sbuf, 1, '$')
  AssertEqual 'My command:', lines[0], 'first line should be the title'
  Assert lines[1] =~# '^[━\-]\+$', 'second line should be a separator'

Execute (footer appends summary lines with leading blank line):
  call plugin_manager#ui#open_sidebar(['Header'])
  let sbuf = bufnr('PluginManager')
  let before = len(getbufline(sbuf, 1, '$'))
  call plugin_manager#ui#footer([plugin_manager#ui#success('Done')])
  let after_lines = getbufline(sbuf, 1, '$')
  Assert len(after_lines) > before, 'footer should append lines'
  " The blank line separator should appear before the summary
  Assert match(after_lines, '^$') >= 0, 'footer should prepend a blank separator line'

Execute (get_status_glyph maps keyword to glyph):
  let tick = plugin_manager#ui#get_symbol('tick')
  let cross = plugin_manager#ui#get_symbol('cross')
  let warn = plugin_manager#ui#get_symbol('warning')
  let info = plugin_manager#ui#get_symbol('info')
  AssertEqual tick,  plugin_manager#ui#get_status_glyph('ok'),   'ok -> tick'
  AssertEqual cross, plugin_manager#ui#get_status_glyph('fail'), 'fail -> cross'
  AssertEqual warn,  plugin_manager#ui#get_status_glyph('warn'), 'warn -> warning'
  AssertEqual info,  plugin_manager#ui#get_status_glyph('info'), 'info -> info'
  AssertEqual info,  plugin_manager#ui#get_status_glyph('skip'), 'skip -> info'

Execute (get_status_glyph accepts legacy boolean - non-zero is ok):
  let tick  = plugin_manager#ui#get_symbol('tick')
  let cross = plugin_manager#ui#get_symbol('cross')
  AssertEqual tick,  plugin_manager#ui#get_status_glyph(1), 'non-zero bool -> tick'
  AssertEqual cross, plugin_manager#ui#get_status_glyph(0), 'zero bool -> cross'

Execute (complete_operation with keyword renders correct glyph):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  let opid = plugin_manager#ui#start_operation('myplugin', 'Checking')
  call plugin_manager#ui#complete_operation(opid, 'warn', 'Modified')
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  let warn_glyph = plugin_manager#ui#get_symbol('warning')
  Assert content =~# 'myplugin', 'plugin name should appear'
  Assert content =~# 'Modified', 'status text should appear'
  Assert content =~# warn_glyph, 'warning glyph should appear for warn status'

Execute (complete_operation with legacy boolean 1 renders tick):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  let opid = plugin_manager#ui#start_operation('plugin2', 'Installing')
  call plugin_manager#ui#complete_operation(opid, 1, 'Installed')
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  let tick = plugin_manager#ui#get_symbol('tick')
  Assert content =~# tick, 'legacy boolean 1 should render tick glyph'

Execute (complete_operation with legacy boolean 0 renders cross):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  let opid = plugin_manager#ui#start_operation('plugin3', 'Installing')
  call plugin_manager#ui#complete_operation(opid, 0, 'Failed')
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  let cross = plugin_manager#ui#get_symbol('cross')
  Assert content =~# cross, 'legacy boolean 0 should render cross glyph'

Execute (purge stale operations does not remove active ops):
  call plugin_manager#ui#open_sidebar(['Header'])
  wincmd p
  let opid = plugin_manager#ui#start_operation('keep', 'Running')
  call plugin_manager#ui#_purge_stale_test()
  call plugin_manager#ui#complete_operation(opid, 1, 'Kept')
  let sbuf = bufnr('PluginManager')
  let content = join(getbufline(sbuf, 1, '$'), "\n")
  Assert content =~# 'keep', 'active operation should survive purge'
  Assert content =~# 'Kept', 'completed operation should render normally'
