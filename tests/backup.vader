Before:
  let g:_pm_bkp_saved = {
        \ 'vim_dir':     get(g:, 'plugin_manager_vim_dir', ''),
        \ 'cwd':         getcwd(),
        \ 'plugins_dir': get(g:, 'plugin_manager_plugins_dir', ''),
        \ 'logging':     get(g:, 'plugin_manager_enable_logging', 0),
        \ 'vimrc_path':  get(g:, 'plugin_manager_vimrc_path', ''),
        \ 'auto_commit': get(g:, 'plugin_manager_auto_commit_on_update', 1),
        \ }

  let g:_pm_bkp_root   = tempname()
  let g:_pm_bkp_vim    = g:_pm_bkp_root . '/vim'
  let g:_pm_bkp_remote = g:_pm_bkp_root . '/remote'

  call mkdir(g:_pm_bkp_root, 'p')

  " Remote bare repo (acts as the push target)
  call system('git init --bare ' . shellescape(g:_pm_bkp_remote))
  call system('git -C ' . shellescape(g:_pm_bkp_remote) . ' symbolic-ref HEAD refs/heads/main')

  " Vim config repo with a remote configured
  call mkdir(g:_pm_bkp_vim, 'p')
  call system('git init ' . shellescape(g:_pm_bkp_vim))
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' config user.email "t@t.com"')
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' config user.name "T"')
  call writefile(['# vimrc'], g:_pm_bkp_vim . '/vimrc')
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' add .')
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' commit -m "init"')
  " Pin local branch to 'main' regardless of init.defaultBranch setting so
  " the test is deterministic across environments (CI uses 'master' by default)
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' branch -M main')
  " Add the bare remote so backup can push
  call system('git -C ' . shellescape(g:_pm_bkp_vim) .
        \ ' -c protocol.file.allow=always remote add origin ' . shellescape(g:_pm_bkp_remote))
  " Push initial branch so remote tracks it
  call system('git -C ' . shellescape(g:_pm_bkp_vim) .
        \ ' -c protocol.file.allow=always push -u origin HEAD:main')

  let g:plugin_manager_vim_dir        = g:_pm_bkp_vim
  let g:plugin_manager_plugins_dir    = g:_pm_bkp_vim . '/pack/plugins'
  let g:plugin_manager_enable_logging = 0
  " Leave vimrc_path empty so backup skips the vimrc-copy step and focuses
  " on commit+push, which is what we actually want to test here.
  let g:plugin_manager_vimrc_path     = ''
  let g:plugin_manager_auto_commit_on_update = 1

  execute 'cd ' . fnameescape(g:_pm_bkp_vim)

  let s:_pm_bkp_sbuf = bufnr('PluginManager')
  if s:_pm_bkp_sbuf != -1
    execute 'bwipeout! ' . s:_pm_bkp_sbuf
  endif

After:
  execute 'cd ' . fnameescape(g:_pm_bkp_saved.cwd)
  if isdirectory(g:_pm_bkp_root)
    call delete(g:_pm_bkp_root, 'rf')
  endif
  let g:plugin_manager_vim_dir               = g:_pm_bkp_saved.vim_dir
  let g:plugin_manager_plugins_dir           = g:_pm_bkp_saved.plugins_dir
  let g:plugin_manager_enable_logging        = g:_pm_bkp_saved.logging
  let g:plugin_manager_vimrc_path            = g:_pm_bkp_saved.vimrc_path
  let g:plugin_manager_auto_commit_on_update = g:_pm_bkp_saved.auto_commit
  unlet g:_pm_bkp_saved g:_pm_bkp_root g:_pm_bkp_vim g:_pm_bkp_remote
  let s:_pm_bkp_sbuf2 = bufnr('PluginManager')
  if s:_pm_bkp_sbuf2 != -1
    execute 'bwipeout! ' . s:_pm_bkp_sbuf2
  endif

Execute (backup with no changes pushes to remote without new commit):
  " No uncommitted changes: backup should push current HEAD without committing.
  let g:_pm_bkp_local = substitute(
        \ system('git -C ' . shellescape(g:_pm_bkp_vim) . ' rev-parse HEAD'),
        \ '\n', '', 'g')

  call plugin_manager#cmd#backup#execute()

  let g:_pm_bkp_remote_head = substitute(
        \ system('git -C ' . shellescape(g:_pm_bkp_remote) . ' rev-parse main'),
        \ '\n', '', 'g')
  AssertEqual g:_pm_bkp_local, g:_pm_bkp_remote_head,
        \ 'remote HEAD should match local HEAD after no-change backup'
  unlet g:_pm_bkp_local g:_pm_bkp_remote_head

Execute (backup with uncommitted changes commits then pushes):
  " Stage a new file (simulates a real change to commit)
  call writefile(['new file'], g:_pm_bkp_vim . '/newfile.txt')
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' add newfile.txt')

  let g:_pm_remote_before = substitute(
        \ system('git -C ' . shellescape(g:_pm_bkp_remote) . ' rev-parse main'),
        \ '\n', '', 'g')

  call plugin_manager#cmd#backup#execute()

  let g:_pm_remote_after = substitute(
        \ system('git -C ' . shellescape(g:_pm_bkp_remote) . ' rev-parse main'),
        \ '\n', '', 'g')

  AssertNotEqual g:_pm_remote_before, g:_pm_remote_after,
        \ 'a new commit should be pushed when there were staged changes'
  unlet g:_pm_remote_before g:_pm_remote_after

Execute (backup with no remote shows warning in sidebar):
  " Remove the remote so push has nowhere to go
  call system('git -C ' . shellescape(g:_pm_bkp_vim) . ' remote remove origin')

  call plugin_manager#cmd#backup#execute()

  " Sidebar should mention the error (no crash, graceful handling)
  let g:_pm_bkp_sbuf = bufnr('PluginManager')
  if g:_pm_bkp_sbuf != -1
    let g:_pm_bkp_content = join(getbufline(g:_pm_bkp_sbuf, 1, '$'), "\n")
    Assert g:_pm_bkp_content =~# '\cNo remotes\|no remote\|warn\|error\|fail',
          \ 'sidebar should indicate no-remote condition: ' . g:_pm_bkp_content
    unlet g:_pm_bkp_content
  endif
  unlet g:_pm_bkp_sbuf
