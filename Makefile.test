# Makefile.test - compatibility shim
#
# All test targets are now defined in the main Makefile.  This file exists
# solely for backwards compatibility with existing scripts and CI pipelines
# that invoke:
#
#   make -f Makefile.test [VADER=./vader.vim] [VIM=vim] test-ci
#
# The VADER variable (pointing to the vader.vim directory) is mapped to the
# VADER_DIR variable expected by the main Makefile.  All other variables are
# forwarded transparently.

# Map the legacy VADER=./vader.vim argument to VADER_DIR used by the main
# Makefile, falling back to the main Makefile's own default when unset.
ifdef VADER
  VADER_DIR_ARG := VADER_DIR=$(VADER)
else
  VADER_DIR_ARG :=
endif

.PHONY: test test-ci clean

test:
	$(MAKE) -f Makefile $(VADER_DIR_ARG) test

test-ci:
	$(MAKE) -f Makefile $(VADER_DIR_ARG) test-ci

clean:
	$(MAKE) -f Makefile clean
